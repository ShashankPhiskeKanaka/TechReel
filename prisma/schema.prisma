// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CREATOR
  USER
}

model users {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  username     String    @unique
  password     String
  role         Role
  verified     Boolean
  authProvider String    @map("auth_provider") // Mapped
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6) // Mapped
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6) // Mapped

  profile      user_profiles?
  refreshTokens refresh_tokens[]

  tokenLedger  token_ledger[]
  xpLedger     xp_ledger[]
  reels        reels[]
  tokenBalance user_token_balance?
  skills       user_skills[]
  streak       streaks?

  reelViews    reel_views[]
  reelLikes    reel_likes[]
  reelReport   reel_reports[]
  reelSaves    reel_saves[]

  badges       user_badges[]
  challengeSubmissions challenge_submissions[]

  @@map("users")
  @@index([id, createdAt])
}

model user_profiles {
  id            String  @id @default(uuid()) @db.Uuid
  userId        String  @unique @map("user_id") @db.Uuid // Mapped
  name          String?
  bio           String?
  avatarUrl     String? @map("avatar_url") // Mapped
  skillsSummary String? @map("skills_summary") // Mapped
  xp            Int     @default(0)
  interests     Json

  user          users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
  @@index([userId])
}

model audit_logs {
  id          String   @id @default(uuid()) @db.Uuid
  model       String
  modelId     String   @map("model_id") @db.Uuid // Mapped
  action      String
  oldData     Json?    @map("old_data") // Mapped
  newData     Json?    @map("new_data") // Mapped
  performedBy String?  @map("performed_by") @db.Uuid // Mapped
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6) // Mapped

  @@map("audit_logs")
  @@index([id, createdAt])
}

model refresh_tokens {
  id        String   @id @default(uuid()) @db.Uuid
  familyId  String   @map("family_id") @db.Uuid // Mapped
  userId    String   @map("user_id") @db.Uuid   // Mapped
  role      Role     @default(USER)
  isUsed    Boolean  @default(false) @map("is_used") // Mapped
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6) // Mapped

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([familyId])
  @@index([userId])
}

model tokens {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  tokenUrl  String?   @map("token_url") // Mapped
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz // Mapped
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz // Mapped

  tokenLedger      token_ledger[]
  userTokenBalance user_token_balance[]

  @@map("tokens")
  @@index([id, createdAt])
}

model skills {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  category    String?
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz // Mapped
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz // Mapped

  reels      reels[]
  userSkills user_skills[]
  roadmap    skill_roadmaps[]
  badges     badges[]

  @@map("skills")
  @@index([id, createdAt])
}


model tags {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("tags")
  @@index([id, createdAt])
}


enum levels {
  NOVICE
  COMPETENT
  PROFICIENT
}

enum status {
  UPLOADED
  PENDING
  FAILED
}

model reels {
  id              String    @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  videoUrl        String?   @map("video_url") // Mapped
  creatorId       String    @map("creator_id") @db.Uuid // Mapped
  skillId         String    @map("skill_id") @db.Uuid // Mapped
  difficultyLevel levels    @map("difficulty_level") // Mapped
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz // Mapped
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz // Mapped
  duration        Int       @default(0)
  tags            Json?
  views           Int       @default(0)
  status          status
  thumbnailUrl    String?   @map("thumbnail_url") // Mapped
  isBonus         Boolean   @default(false) @map("is_bonus") // Mapped
  likes           Int       @default(0)

  user            users     @relation(fields: [creatorId], references: [id])
  skill           skills    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  reelViews       reel_views[]
  reelLikes       reel_likes[]
  reelReports     reel_reports[]
  reelSaves       reel_saves[]

  challenges      challenges?

  @@map("reels")
  @@index([id, createdAt])
}

enum TransactionType{
  DEBIT
  CREDIT
}

model token_ledger {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  tokenId   String          @map("token_id") @db.Uuid
  amount    Int
  source    String
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz
  type      TransactionType

  user  users  @relation(fields: [userId], references: [id])
  token tokens @relation(fields: [tokenId], references: [id])

  @@map("token_ledger")
  @@index([id, createdAt])
  @@index([userId])
}

model user_token_balance {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  tokenId   String   @map("token_id") @db.Uuid
  amount    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  users  @relation(fields: [userId], references: [id])
  token tokens @relation(fields: [tokenId], references: [id])

  @@map("user_token_balance")
  @@index([id, createdAt])
  @@index([userId])
}

model xp_ledger {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  amount    Int
  source    String
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime?       @map("deleted_at") @db.Timestamptz
  type      TransactionType

  user users @relation(fields: [userId], references: [id])

  @@map("xp_ledger")
  @@index([userId])
  @@index([id, createdAt])
}


model streaks {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  currentStreak Int      @map("current_streak")
  longestStreak Int      @map("longest_streak")
  lastActive    DateTime @map("last_active") @db.Timestamptz

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
  @@index([userId])
}

model user_skills {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  skillId         String   @map("skill_id") @db.Uuid
  xp              Int
  difficultyLevel levels   @map("difficulty_level")
  lastUpdated     DateTime @map("last_updated") @db.Timestamptz
  progress        Int
  completedAt     DateTime @map("completed_at") @db.Timestamptz

  user  users  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill skills @relation(fields: [skillId], references: [id])

  @@map("user_skills")
  @@index([userId])
  @@index([id, completedAt])
}

model skill_roadmaps {
  id              String   @id @default(uuid()) @db.Uuid
  skillId         String   @map("skill_id") @db.Uuid
  difficultyLevel levels   @map("difficulty_level")
  title           String
  description     String
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  skill skills @relation(fields: [skillId], references: [id], onDelete: Cascade)

  roadmapSteps roadmap_steps[]

  @@map("skill_roadmaps")
  @@index([skillId])
}

model reel_views {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  reelId         String   @map("reel_id") @db.Uuid
  watchedSeconds Int      @default(0) @map("watched_seconds")
  completed      Boolean
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user users @relation(fields: [userId], references: [id])
  reel reels @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@map("reel_views")
  @@index([id, createdAt])
}

model reel_likes {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  reelId    String   @map("reel_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user users @relation(fields: [userId], references: [id])
  reel reels @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@unique([userId, reelId])
  @@map("reel_likes")
  @@index([id, createdAt])
}

model reel_saves {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  reelId     String   @map("reel_id") @db.Uuid
  folderName String   @map("folder_name")
  savedAt    DateTime @default(now()) @map("saved_at") @db.Timestamptz

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel reels @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@map("reel_saves")
  @@index([folderName])
  @@index([id, savedAt])
}


enum reportStatus {
  PENDING
  APPROVED 
  REJECTED
}
model reel_reports {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  reelId    String       @map("reel_id") @db.Uuid
  reason    String
  status    reportStatus
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel reels @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@map("reel_reports")
  @@index([id, createdAt])
}


enum challenge_type {
  MCQ
  FIB
  TF
  OP
}

model challenges {
  id              String         @id @default(uuid()) @db.Uuid
  reelId          String         @map("reel_id") @db.Uuid @unique
  question        String
  codeSnippet     String?        @map("code_snippet")
  language        String
  challengeType   challenge_type @map("challenge_type")
  answer          String
  difficultyLevel levels         @map("difficulty_level")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz

  reels                reels                  @relation(fields: [reelId], references: [id])
  challengeSubmissions challenge_submissions[]
  challengeOptions     challenge_options[]

  @@map("challenges")
  @@index([id, createdAt])
}

model badges {
  id          String    @id @default(uuid()) @db.Uuid
  skillId     String    @map("skill_id") @db.Uuid
  name        String
  description String?
  iconUrl     String?   @map("icon_url")
  xpReward    Int       @map("xp_reward")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  skill      skills        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userBadges user_badges[]

  @@map("badges")
  @@index([id, createdAt])
}

model user_badges {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  badgeId   String   @map("badge_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  users  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge badges @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@map("user_badges")
  @@index([id, createdAt])
}


model roadmap_steps {
  id          String  @id @default(uuid()) @db.Uuid
  roadmapId   String  @map("roadmap_id") @db.Uuid
  reelId      String  @map("reel_id") @db.Uuid
  challengeId String  @map("challenge_id") @db.Uuid
  stepOrder   Int     @map("step_order")
  title       String
  description String?

  roadmap             skill_roadmaps         @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  challengeSubmissions challenge_submissions[]

  @@map("roadmap_steps")
}

model challenge_submissions {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  challengeId   String         @map("challenge_id") @db.Uuid
  answer        String
  isCorrect     Boolean        @map("is_correct")
  score         Int
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  roadmapStepId String?        @map("roadmap_step_id") @db.Uuid

  user        users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   challenges     @relation(fields: [challengeId], references: [id])
  roadmapStep roadmap_steps? @relation(fields: [roadmapStepId], references: [id])

  @@map("challenge_submissions")
  @@index([id, createdAt])
}

model challenge_options {
  id          String     @id @default(uuid()) @db.Uuid
  challengeId String     @map("challenge_id") @db.Uuid
  isCorrect   Boolean    @map("is_correct")
  option      String

  challenge   challenges @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@map("challenge_options")
}
